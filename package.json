{
  "name": "@zahardev/aicontext",
  "version": "1.3.0",
  "description": "Give your AI coding assistants persistent memory about your project. Works with any language (PHP, Python, JS, Rust, Go) and framework (Laravel, Django, Next.js, WordPress). Supports Claude Code, Cursor, and GitHub Copilot.",
  "keywords": [
    "ai",
    "claude",
    "cursor",
    "copilot",
    "context",
    "coding-assistant",
    "developer-tools",
    "laravel",
    "wordpress",
    "django",
    "nextjs",
    "nestjs",
    "flutter",
    "ai-context",
    "project-context"
  ],
  "author": "Serhiy Zakharchenko (zahardev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zahardev/aicontext.git"
  },
  "homepage": "https://github.com/zahardev/aicontext#readme",
  "bugs": {
    "url": "https://github.com/zahardev/aicontext/issues"
  },
  "bin": {
    "aicontext": "./bin/aicontext.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js"
  },
  "files": [
    "bin/",
    ".aicontext/rules/",
    ".aicontext/prompts/",
    ".aicontext/templates/",
    ".aicontext/tasks/.gitkeep",
    ".aicontext/data/.gitignore",
    ".aicontext/readme.md",
    ".aicontext/changelog.md",
    ".aicontext/.gitignore",
    ".claude/",
    ".cursor/",
    ".github/copilot-instructions.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
