{
  "name": "@zahardev/aicontext",
  "version": "1.6.0",
  "description": "Stop re-explaining your project every session — persistent context that survives across sessions and features. Teach your AI to plan, build, review, and ship. Works with Claude Code, Codex, Cursor, and GitHub Copilot.",
  "keywords": [
    "ai",
    "claude",
    "cursor",
    "codex",
    "copilot",
    "context",
    "coding-assistant",
    "developer-tools",
    "laravel",
    "wordpress",
    "django",
    "nextjs",
    "nestjs",
    "flutter",
    "ai-context",
    "project-context"
  ],
  "author": "Serhiy Zakharchenko (zahardev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zahardev/aicontext.git"
  },
  "homepage": "https://github.com/zahardev/aicontext#readme",
  "bugs": {
    "url": "https://github.com/zahardev/aicontext/issues"
  },
  "bin": {
    "aicontext": "./bin/aicontext.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js"
  },
  "files": [
    "bin/",
    ".aicontext/rules/",
    ".aicontext/prompts/",
    ".aicontext/templates/",
    ".aicontext/tasks/.gitkeep",
    ".aicontext/data/.gitignore",
    ".aicontext/readme.md",
    ".aicontext/changelog.md",
    ".aicontext/.gitignore",
    ".aicontext/scripts/",
    ".claude/",
    ".codex/",
    ".cursor/",
    ".github/copilot-instructions.md"
  ],
  "engines": {
    "node": ">=14.14.0"
  }
}
